<?xml version="1.0"?>
<info xmlns:xsi= "http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <!--
        SPDX-FileCopyrightText: Sendent B.V. <l.pasmans@sendent.com>
        SPDX-License-Identifier: CC0-1.0
    -->
    <id>sendentsynchroniser</id>
    <name>Sendent Sync</name>
    <summary>Synchronise your Calendar and Contacts with Nextcloud</summary>
    <description><![CDATA[Say goodbye to manual updates! The Sendent Sync app, designed for the Nextcloud Exchange Connector, enables bi-directional syncing of agendas and contacts between your Microsoft Exchange and Nextcloud Hub. Focus on what truly matters – your work – while your data flows effortlessly.]]></description>
    <version>2.0.0</version>
    <licence>agpl</licence>
    <author mail="support@sendent.com" homepage="https://www.sendent.com">Sendent B.V.</author>
    <namespace>SendentSynchroniser</namespace>
    <category>integration</category>
    <category>office</category>
    <category>tools</category>
    <website>https://www.sendent.com</website>
    <bugs>https://sendent.com/resources/support</bugs>
    <screenshot>https://download.sendent.com/sendentsynchroniser/1.0.0/sendentbanner.png</screenshot>
    <dependencies>
        <nextcloud min-version="28" max-version="33"/>
    </dependencies>
    <background-jobs>
        <job>OCA\SendentSynchroniser\Cron\NotifyInactiveUsers</job>
    </background-jobs>
    <!--
        Room occ commands are disabled while Constants::ROOMS_FEATURE_ENABLED is false.
        The Command\Rooms\* classes still exist on disk; uncomment the <commands>
        block below AND flip the constant to re-enable.

        IMPORTANT: the comment markers must wrap the entire <commands> element
        (not its body). NC's loadCommandsFromInfoXml iterates the element's
        children and fails with "Argument #1 must be Traversable|array, string
        given" when the body contains only comments / whitespace.
    -->
    <!--
    <commands>
        <command>OCA\SendentSynchroniser\Command\Rooms\ListRooms</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\CreateRoom</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\ShowRoom</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\UpdateRoom</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\DeleteRoom</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\ListGroups</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\CreateGroup</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\DeleteGroup</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\ListPermissions</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\GrantPermission</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\RevokePermission</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\Bind</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\Unbind</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\RetrySync</command>
        <command>OCA\SendentSynchroniser\Command\Rooms\Diagnose</command>
    </commands>
    -->
    <settings>
        <admin>OCA\SendentSynchroniser\Settings\Admin</admin>
        <admin-section>OCA\SendentSynchroniser\Settings\AdminSection</admin-section>
        <personal>OCA\SendentSynchroniser\Settings\User</personal>
        <personal-section>OCA\SendentSynchroniser\Settings\UserSection</personal-section>
    </settings>
</info>
