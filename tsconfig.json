{
    "compilerOptions": {
      "lib": [
        "dom",
        "es2021"
      ],
      "module": "ES6",
      "moduleResolution": "node",
      "target": "ES6",
      "strictNullChecks": true,
      "sourceMap": true,
      "allowSyntheticDefaultImports": true,
      "esModuleInterop": true
    },
    "include": ["src/**/*", "src/**/*.vue"],
    "exclude": ["node_modules"]
}
